{
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "EDITOR": "vim",
    "GIT_EDITOR": "vim",
    "VISUAL": "vim"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(go list*)",
      "Bash(go doc*)",
      "Bash(go version*)",
      "Bash(go env*)",
      "Bash(go mod graph*)",
      "Bash(go mod why*)",
      "Bash(go mod verify*)",
      "Bash(go build -n*)",
      "Bash(golint*)",
      "Bash(staticcheck*)",
      "Bash(gofmt -d*)",
      "Bash(goimports -d*)",
      "Bash(golangci-lint run*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh api*)",
      "Bash(gosec*)",
      "Bash(shellcheck*)",
      "Bash(yamllint*)",
      "Bash(hadolint*)",
      "Bash(buf lint*)",
      "Bash(buf format -d*)",
      "Bash(buf breaking*)",
      "Bash(buf build*)",
      "Bash(trivy*)",
      "Bash(nix flake show*)",
      "Bash(nix flake check*)",
      "Bash(nix flake metadata*)",
      "Bash(nix search*)",
      "Bash(nix eval*)",
      "Bash(nix build --dry-run*)",
      "Bash(nix develop --dry-run*)",
      "Bash(helm list*)",
      "Bash(helm get*)",
      "Bash(helm show*)",
      "Bash(helm template*)",
      "Bash(helm lint*)",
      "Bash(helm history*)",
      "Bash(helm status*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)",
      "Bash(docker inspect*)",
      "Bash(docker stats*)",
      "Bash(docker version*)",
      "Bash(docker info*)",
      "Bash(docker history*)",
      "Bash(docker top*)",
      "Bash(curl -s*)",
      "Bash(curl -I*)",
      "Bash(curl -X GET*)",
      "Bash(du*)",
      "Bash(df*)",
      "Bash(ps*)",
      "Bash(uptime*)",
      "Bash(uname*)",
      "Bash(which*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(tree*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(diff*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(awk*)",
      "Bash(sed -n*)",
      "Bash(chezmoi:*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "NotebookRead",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(eval:*)",
      "Bash(exec:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "../",
      "../../"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
