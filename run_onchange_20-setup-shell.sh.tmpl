#!/bin/bash
# Shell setup script
# Runs whenever this script changes
# Profile: {{ .profile }}

set -e

echo "Setting up shell environment for {{ .profile }} profile..."

# Append a line to a file only once
append_once() {
    local line="$1"
    local file="$2"

    if [[ -z "$line" || -z "$file" ]]; then
        return 1
    fi

    touch "$file"
    if ! grep -Fqx "$line" "$file" 2>/dev/null; then
        echo "$line" >> "$file"
    fi
}

# Install fzf key bindings and fuzzy completion
if command -v fzf >/dev/null 2>&1; then
    echo "Setting up fzf..."

    # Install fzf keybindings for bash
    if [[ -f /usr/share/doc/fzf/examples/key-bindings.bash ]]; then
        append_once "source /usr/share/doc/fzf/examples/key-bindings.bash" "$HOME/.bashrc.local"
    elif [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.bash ]]; then
        append_once "source /opt/homebrew/opt/fzf/shell/key-bindings.bash" "$HOME/.bashrc.local"
    fi

    # Install fzf keybindings for zsh
    if command -v zsh >/dev/null 2>&1; then
        if [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
            append_once "source /usr/share/doc/fzf/examples/key-bindings.zsh" "$HOME/.zshrc.local"
        elif [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]]; then
            append_once "source /opt/homebrew/opt/fzf/shell/key-bindings.zsh" "$HOME/.zshrc.local"
        fi
    fi
fi

{{- if .features.editors_full }}
# Install Vim plugins if vim-plug is available (timeout after 60s to avoid blocking)
if command -v vim >/dev/null 2>&1 && [[ -f ~/.vim/autoload/plug.vim ]]; then
    echo "Installing Vim plugins..."
    timeout 60 vim +PlugInstall +PlugUpdate +qall 2>/dev/null || echo "Vim plugin install timed out or failed — run 'vim +PlugInstall' manually"
fi
{{- end }}

{{- if .features.tmux }}
# Install TPM (Tmux Plugin Manager) if not present
if [[ ! -d ~/.tmux/plugins/tpm ]]; then
    echo "Installing TPM (Tmux Plugin Manager)..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
fi
# Install tmux plugins via TPM
if [[ -x ~/.tmux/plugins/tpm/bin/install_plugins ]]; then
    echo "Installing tmux plugins..."
    ~/.tmux/plugins/tpm/bin/install_plugins || true
fi
{{- end }}

{{- if .features.nodejs }}
# Node.js: fnm is installed via user-space tools (run_onchange_15-install-user-tools.sh)
# Install a default Node.js version if fnm is available and no version installed
if command -v fnm >/dev/null 2>&1; then
    if ! fnm list 2>/dev/null | grep -q "v"; then
        echo "Installing Node.js LTS via fnm..."
        fnm install --lts || true
    fi
fi
{{- end }}

{{- if .features.python }}
# Python: uv is installed via user-space tools (run_onchange_15-install-user-tools.sh)
# uv can manage Python versions - no need for pyenv
if command -v uv >/dev/null 2>&1; then
    echo "Python version management available via 'uv python install <version>'"
fi
{{- end }}

echo "Shell setup complete!"
