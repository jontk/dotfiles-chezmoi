#!/bin/bash
# Shell setup script
# Runs whenever this script changes
# Profile: {{ .profile }}

set -e

echo "Setting up shell environment for {{ .profile }} profile..."

# Append a line to a file only once
append_once() {
    local line="$1"
    local file="$2"

    if [[ -z "$line" || -z "$file" ]]; then
        return 1
    fi

    touch "$file"
    if ! grep -Fqx "$line" "$file" 2>/dev/null; then
        echo "$line" >> "$file"
    fi
}

# Install fzf key bindings and fuzzy completion
if command -v fzf >/dev/null 2>&1; then
    echo "Setting up fzf..."

    # Install fzf keybindings for bash
    if [[ -f /usr/share/doc/fzf/examples/key-bindings.bash ]]; then
        append_once "source /usr/share/doc/fzf/examples/key-bindings.bash" "$HOME/.bashrc.local"
    elif [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.bash ]]; then
        append_once "source /opt/homebrew/opt/fzf/shell/key-bindings.bash" "$HOME/.bashrc.local"
    fi

    # Install fzf keybindings for zsh
    if command -v zsh >/dev/null 2>&1; then
        if [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
            append_once "source /usr/share/doc/fzf/examples/key-bindings.zsh" "$HOME/.zshrc.local"
        elif [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]]; then
            append_once "source /opt/homebrew/opt/fzf/shell/key-bindings.zsh" "$HOME/.zshrc.local"
        fi
    fi
fi

{{- if .features.tmux }}
# Install TPM (Tmux Plugin Manager) if not present
if [[ ! -d ~/.tmux/plugins/tpm ]]; then
    echo "Installing TPM (Tmux Plugin Manager)..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    echo "TPM installed. Run 'prefix + I' in tmux to install plugins."
fi
{{- end }}

{{- if .features.nodejs }}
# Install NVM if not present
if [[ ! -d ~/.nvm ]]; then
    if [[ "${CHEZMOI_ALLOW_REMOTE_INSTALL:-}" == "1" ]]; then
        echo "Installing NVM (Node Version Manager)..."
        curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash
        export NVM_DIR="$HOME/.nvm"
        [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
        nvm install --lts
    else
        echo "Skipping NVM install (set CHEZMOI_ALLOW_REMOTE_INSTALL=1 to enable)"
    fi
fi
{{- end }}

{{- if .features.python }}
# Install pyenv if not present
if [[ ! -d ~/.pyenv ]] && command -v pyenv >/dev/null 2>&1; then
    echo "Pyenv is already installed via package manager"
elif [[ ! -d ~/.pyenv ]]; then
    if [[ "${CHEZMOI_ALLOW_REMOTE_INSTALL:-}" == "1" ]]; then
        echo "Installing pyenv..."
        curl -fsSL https://pyenv.run | bash
    else
        echo "Skipping pyenv install (set CHEZMOI_ALLOW_REMOTE_INSTALL=1 to enable)"
    fi
fi
{{- end }}

echo "Shell setup complete!"
