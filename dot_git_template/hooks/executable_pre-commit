#!/usr/bin/env bash
# Git pre-commit hook
# Portable version that works without Nix dependencies

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Debug mode
if [[ -n "$DEBUG" ]]; then
    set -x
fi

echo -e "${BLUE}Running pre-commit checks...${NC}"

# Check for merge conflicts
echo "Checking for merge conflict markers..."
if git diff --cached --name-only | xargs grep -l -E '^(<<<<<<<|=======|>>>>>>>)' 2>/dev/null; then
    echo -e "${RED}Error: Merge conflict markers found in staged files:${NC}"
    git diff --cached --name-only | xargs grep -n -E '^(<<<<<<<|=======|>>>>>>>)' 2>/dev/null || true
    exit 1
fi

# Check for large files (>10MB)
echo "Checking for large files..."
large_files_found=false
while read -r file; do
    if [[ -f "$file" ]]; then
        # Detect stat command flavor by testing flags
        if stat -f%z "$file" >/dev/null 2>&1; then
            # BSD stat (macOS default)
            size=$(stat -f%z "$file" 2>/dev/null || echo 0)
        else
            # GNU stat (Linux, or GNU coreutils on macOS)
            size=$(stat -c%s "$file" 2>/dev/null || echo 0)
        fi
        
        if [[ "$size" -gt 10485760 ]]; then  # 10MB
            echo -e "${RED}Error: Large file detected: $file${NC}"
            if command -v numfmt >/dev/null 2>&1; then
                echo "  Size: $(numfmt --to=iec-i --suffix=B "$size")"
            else
                echo "  Size: $size bytes"
            fi
            large_files_found=true
        fi
    fi
done < <(git diff --cached --name-only)

if [[ "$large_files_found" == "true" ]]; then
    echo "Consider using Git LFS for large files"
    exit 1
fi

# Check for binary files
echo "Checking for binary executable files..."
binary_files_found=false

# List of binary file extensions to block
BINARY_EXTENSIONS="exe|dll|so|dylib|a|o|bin|dat|class|pyc|pyo|obj|lib|app"

# Check for files with binary extensions
while read -r file; do
    if [[ -f "$file" ]] && echo "$file" | grep -qE "\.(${BINARY_EXTENSIONS})$"; then
        echo -e "${RED}Error: Binary file detected: $file${NC}"
        echo "  Extension: .$(echo "$file" | sed 's/.*\.//')"
        binary_files_found=true
    fi
done < <(git diff --cached --name-only --diff-filter=A)

# Check for executable binaries without extensions (compiled programs)
while read -r file; do
    if [[ -f "$file" ]]; then
        # Use file command to detect binary executables
        if file "$file" | grep -qE "(ELF|PE32|Mach-O|executable|compiled)"; then
            # Skip files in common binary directories that should be allowed
            if ! echo "$file" | grep -qE "^(vendor/|node_modules/|\.venv/|venv/)"; then
                echo -e "${RED}Error: Compiled binary detected: $file${NC}"
                file_type=$(file "$file" | cut -d: -f2)
                echo "  Type:$file_type"
                binary_files_found=true
            fi
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=A)

if [[ "$binary_files_found" == "true" ]]; then
    echo -e "${RED}Binary files should not be committed to git.${NC}"
    echo "Add them to .gitignore or use Git LFS for necessary binaries."
    echo ""
    echo "To bypass this check: git commit --no-verify"
    exit 1
fi


# Check for sensitive data patterns
echo "Checking for sensitive data patterns..."
sensitive_patterns=(
    "PRIVATE KEY"
    "private_key"
    "aws_access_key_id"
    "aws_secret_access_key"
    "api_key"
    "apikey"
    "access_token"
    "auth_token"
    "credentials"
    "password"
    "passwd"
    "secret_key"
    "SECRET_KEY"
    "token"
    "TOKEN"
)

sensitive_found=false
for pattern in "${sensitive_patterns[@]}"; do
    if git diff --cached --name-only | xargs grep -i -l "$pattern" 2>/dev/null; then
        echo -e "${YELLOW}Warning: Possible sensitive data found (pattern: $pattern)${NC}"
        git diff --cached --name-only | xargs grep -i -n "$pattern" 2>/dev/null || true
        sensitive_found=true
    fi
done

if [[ "$sensitive_found" == "true" ]]; then
    echo -e "${YELLOW}Please review and ensure no secrets are being committed${NC}"
    read -p "Continue anyway? (y/N) " -n 1 -r response
    echo
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Check and auto-fix trailing whitespace
echo "Checking for trailing whitespace..."
if ! git diff --cached --check >/dev/null 2>&1; then
    echo -e "${YELLOW}Auto-fixing trailing whitespace...${NC}"
    
    # Get files with trailing whitespace
    files_with_whitespace=$(git diff --cached --check 2>&1 | sed 's/:.*$//' | sort -u)
    
    # Fix trailing whitespace in each file
    for file in $files_with_whitespace; do
        if [[ -f "$file" ]]; then
            echo "  Fixing: $file"
            # Detect sed flavor by testing behavior, not OS
            if sed --version >/dev/null 2>&1; then
                # GNU sed (supports --version)
                sed -i 's/[[:space:]]*$//' "$file"
            else
                # BSD sed (macOS default, doesn't support --version)
                sed -i '' 's/[[:space:]]*$//' "$file"
            fi
            # Re-stage the fixed file
            git add "$file"
        fi
    done
    
    echo -e "${GREEN}✓ Trailing whitespace fixed and re-staged${NC}"
fi

# Language-specific formatting checks
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

# Python formatting check
python_files=$(echo "$staged_files" | grep -E '\.py$' || true)
if [[ -n "$python_files" ]]; then
    echo "Checking Python files..."
    
    # Check with black if available
    if command -v black >/dev/null 2>&1; then
        if ! echo "$python_files" | xargs black --check --quiet 2>/dev/null; then
            echo -e "${YELLOW}Warning: Python files not formatted with black${NC}"
            echo "Run: echo '$python_files' | xargs black"
        fi
    fi
    
    # Check with flake8 if available
    if command -v flake8 >/dev/null 2>&1; then
        if ! echo "$python_files" | xargs flake8 --max-line-length=88 2>/dev/null; then
            echo -e "${YELLOW}Warning: Python linting issues found${NC}"
        fi
    fi
fi

# JavaScript/TypeScript formatting check
js_files=$(echo "$staged_files" | grep -E '\.(js|jsx|ts|tsx)$' || true)
if [[ -n "$js_files" ]]; then
    echo "Checking JavaScript/TypeScript files..."
    
    if command -v prettier >/dev/null 2>&1; then
        if ! echo "$js_files" | xargs prettier --check 2>/dev/null; then
            echo -e "${YELLOW}Warning: JS/TS files not formatted with prettier${NC}"
            echo "Run: echo '$js_files' | xargs prettier --write"
        fi
    fi
    
    if command -v eslint >/dev/null 2>&1; then
        if ! echo "$js_files" | xargs eslint 2>/dev/null; then
            echo -e "${YELLOW}Warning: ESLint issues found${NC}"
        fi
    fi
fi

# Go formatting check
go_files=$(echo "$staged_files" | grep -E '\.go$' || true)
if [[ -n "$go_files" ]]; then
    echo "Checking Go files..."
    
    if command -v gofmt >/dev/null 2>&1; then
        if ! echo "$go_files" | xargs gofmt -l | grep -q .; then
            : # Files are formatted
        else
            echo -e "${YELLOW}Warning: Go files not formatted${NC}"
            echo "Run: echo '$go_files' | xargs gofmt -w"
        fi
    fi
    
    if command -v go >/dev/null 2>&1; then
        if ! go vet ./... 2>/dev/null; then
            echo -e "${YELLOW}Warning: Go vet issues found${NC}"
        fi
    fi
fi

# Rust formatting check
rust_files=$(echo "$staged_files" | grep -E '\.rs$' || true)
if [[ -n "$rust_files" ]]; then
    echo "Checking Rust files..."
    
    if command -v rustfmt >/dev/null 2>&1; then
        if ! echo "$rust_files" | xargs rustfmt --check 2>/dev/null; then
            echo -e "${YELLOW}Warning: Rust files not formatted${NC}"
            echo "Run: echo '$rust_files' | xargs rustfmt"
        fi
    fi
    
    if command -v cargo >/dev/null 2>&1; then
        if ! cargo clippy --quiet 2>/dev/null; then
            echo -e "${YELLOW}Warning: Cargo clippy issues found${NC}"
        fi
    fi
fi

# Shell script checks
shell_files=$(echo "$staged_files" | grep -E '\.(sh|bash|zsh)$' || true)
if [[ -n "$shell_files" ]]; then
    echo "Checking shell scripts..."
    
    if command -v shellcheck >/dev/null 2>&1; then
        if ! echo "$shell_files" | xargs shellcheck 2>/dev/null; then
            echo -e "${YELLOW}Warning: Shellcheck issues found${NC}"
        fi
    fi
fi

# YAML/JSON formatting checks
yaml_files=$(echo "$staged_files" | grep -E '\.(yml|yaml)$' || true)
if [[ -n "$yaml_files" ]]; then
    echo "Checking YAML files..."
    
    if command -v yamllint >/dev/null 2>&1; then
        if ! echo "$yaml_files" | xargs yamllint -d relaxed 2>/dev/null; then
            echo -e "${YELLOW}Warning: YAML formatting issues found${NC}"
        fi
    fi
fi

json_files=$(echo "$staged_files" | grep -E '\.json$' || true)
if [[ -n "$json_files" ]]; then
    echo "Checking JSON files..."
    
    for file in $json_files; do
        if ! python3 -m json.tool "$file" >/dev/null 2>&1; then
            echo -e "${YELLOW}Warning: Invalid JSON in $file${NC}"
        fi
    done
fi

# Markdown checks
markdown_files=$(echo "$staged_files" | grep -E '\.(md|markdown)$' || true)
if [[ -n "$markdown_files" ]]; then
    echo "Checking Markdown files..."
    
    if command -v markdownlint >/dev/null 2>&1; then
        if ! echo "$markdown_files" | xargs markdownlint 2>/dev/null; then
            echo -e "${YELLOW}Warning: Markdown linting issues found${NC}"
        fi
    fi
fi

# Check for TODO/FIXME comments in staged files
todo_check=$(git diff --cached | grep -E '^[+].*\b(TODO|FIXME|XXX|HACK)\b' || true)
if [[ -n "$todo_check" ]]; then
    echo -e "${YELLOW}Note: Found TODO/FIXME comments in staged changes:${NC}"
    echo "$todo_check"
fi

echo -e "${GREEN}✓ Pre-commit checks completed${NC}"
