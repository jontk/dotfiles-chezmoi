# GnuPG Agent Configuration
# Managed by chezmoi

# Cache settings (in seconds)
default-cache-ttl 600
max-cache-ttl 7200

# Enable SSH agent support
enable-ssh-support

# Use pinentry program based on environment
{{- if eq .chezmoi.os "darwin" }}
# macOS: Use pinentry-mac if available
pinentry-program /opt/homebrew/bin/pinentry-mac
{{- else if lookPath "pinentry-gnome3" }}
# Linux with GNOME
pinentry-program /usr/bin/pinentry-gnome3
{{- else if lookPath "pinentry-qt" }}
# Linux with Qt
pinentry-program /usr/bin/pinentry-qt
{{- else if lookPath "pinentry-curses" }}
# Fallback to curses
pinentry-program /usr/bin/pinentry-curses
{{- end }}

# Allow preset passphrases
allow-preset-passphrase

# Enable extra socket for remote GPG operations
# enable-extra-socket
