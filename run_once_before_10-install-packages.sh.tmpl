#!/bin/bash
# One-time package installation script
# Runs before chezmoi applies dotfiles
# Profile: {{ .profile }}

set -e

echo "Installing packages for {{ .profile }} profile on {{ .chezmoi.os }}..."

# Verify SHA256 checksum (supports sha256sum or shasum)
verify_sha256() {
    local file="$1"
    local expected="$2"
    local actual=""

    if command -v sha256sum >/dev/null 2>&1; then
        actual=$(sha256sum "$file" | awk '{print $1}')
    elif command -v shasum >/dev/null 2>&1; then
        actual=$(shasum -a 256 "$file" | awk '{print $1}')
    else
        echo "Warning: sha256sum/shasum not available; cannot verify $file"
        return 1
    fi

    if [[ "$actual" != "$expected" ]]; then
        echo "Error: SHA256 mismatch for $file"
        echo "  Expected: $expected"
        echo "  Actual:   $actual"
        return 1
    fi
}

{{- if eq .chezmoi.os "darwin" }}
# macOS: Homebrew packages
if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew not found. Please install from https://brew.sh"
    exit 1
fi

echo "Installing Homebrew packages..."
brew bundle --no-lock --file=/dev/stdin <<EOF
# Core utilities
brew "git"
brew "fzf"
brew "ripgrep"
brew "fd"
brew "bat"
brew "eza"  # Modern replacement for exa (deprecated)
brew "jq"
brew "curl"
brew "wget"

{{- if .features.starship }}
# Starship prompt
brew "starship"
{{- end }}

{{- if .features.tmux }}
# Tmux
brew "tmux"
brew "reattach-to-user-namespace"
{{- end }}

{{- if .features.editors_full }}
# Editors
brew "vim"
{{- if .features.beta_features }}
brew "neovim"
{{- end }}
{{- end }}

{{- if .features.nodejs }}
# Node.js tools
brew "node"
{{- end }}

{{- if .features.python }}
# Python tools
brew "python"
brew "pyenv"
{{- end }}

{{- if .features.golang }}
# Go
brew "go"
brew "golangci-lint"
{{- end }}

{{- if .features.docker }}
# Docker
cask "docker"
{{- end }}

{{- if .features.kubernetes }}
# Kubernetes tools
brew "kubectl"
brew "k9s"
brew "helm"
brew "kubectx"
{{- end }}

# Development tools
brew "tree"
brew "htop"
brew "watch"
brew "tldr"
brew "gh"

EOF

{{- else if eq .chezmoi.osRelease.id "fedora" }}
# Fedora
echo "Installing DNF packages..."
pkgs=(
    git
    fzf
    ripgrep
    fd-find
    bat
    jq
    curl
    wget
    tree
    htop
)
{{- if .features.starship }}
pkgs+=(starship)
{{- end }}
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.nodejs }}
pkgs+=(nodejs npm)
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-devel)
{{- end }}
{{- if .features.golang }}
pkgs+=(golang)
{{- end }}
{{- if .features.docker }}
pkgs+=(docker docker-compose)
{{- end }}
{{- if .features.kubernetes }}
pkgs+=(kubectl)
{{- end }}
sudo dnf install -y "${pkgs[@]}"


{{- else if eq .chezmoi.osRelease.id "ubuntu" }}
# Ubuntu/Debian
echo "Installing APT packages..."
pkgs=(
    git
    fzf
    ripgrep
    fd-find
    bat
    jq
    curl
    wget
    tree
    htop
    build-essential
)
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.nodejs }}
pkgs+=(nodejs npm)
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-venv python3-dev)
{{- end }}
{{- if .features.golang }}
pkgs+=(golang)
{{- end }}
{{- if .features.docker }}
pkgs+=(docker.io docker-compose)
{{- end }}
sudo apt update
sudo apt install -y "${pkgs[@]}"


{{- if .features.starship }}
# Install starship (not in Ubuntu repos)
if [[ "${CHEZMOI_ALLOW_REMOTE_INSTALL:-}" == "1" ]]; then
    STARSHIP_INSTALLER="/tmp/starship-install-$$.sh"
    curl -fsSL https://starship.rs/install.sh -o "$STARSHIP_INSTALLER"
    chmod +x "$STARSHIP_INSTALLER"
    "$STARSHIP_INSTALLER" -y
    rm "$STARSHIP_INSTALLER"
else
    echo "Skipping starship install (set CHEZMOI_ALLOW_REMOTE_INSTALL=1 to enable)"
fi
{{- end }}

{{- if .features.kubernetes }}
# Install kubectl (from official k8s repo)
KUBECTL_VERSION=$(curl -fsSL https://dl.k8s.io/release/stable.txt)
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl"
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256"
verify_sha256 "kubectl" "$(cat kubectl.sha256)"
sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
rm kubectl kubectl.sha256
{{- end }}

{{- else if or (eq .chezmoi.osRelease.id "rhel") (eq .chezmoi.osRelease.id "rocky") (eq .chezmoi.osRelease.id "almalinux") }}
# RHEL/Rocky/AlmaLinux
echo "Installing DNF packages..."
pkgs=(
    git
    fzf
    ripgrep
    jq
    curl
    wget
    tree
    htop
)
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-devel)
{{- end }}
sudo dnf install -y "${pkgs[@]}"


{{- if .features.starship }}
# Install starship (not in RHEL repos)
if [[ "${CHEZMOI_ALLOW_REMOTE_INSTALL:-}" == "1" ]]; then
    STARSHIP_INSTALLER="/tmp/starship-install-$$.sh"
    curl -fsSL https://starship.rs/install.sh -o "$STARSHIP_INSTALLER"
    chmod +x "$STARSHIP_INSTALLER"
    "$STARSHIP_INSTALLER" -y
    rm "$STARSHIP_INSTALLER"
else
    echo "Skipping starship install (set CHEZMOI_ALLOW_REMOTE_INSTALL=1 to enable)"
fi
{{- end }}

{{- if .features.nodejs }}
# Install Node.js from NodeSource
if [[ "${CHEZMOI_ALLOW_REMOTE_INSTALL:-}" == "1" ]]; then
    NODESOURCE_SCRIPT="/tmp/nodesource-setup-$$.sh"
    curl -fsSL https://rpm.nodesource.com/setup_lts.x -o "$NODESOURCE_SCRIPT"
    chmod +x "$NODESOURCE_SCRIPT"
    sudo bash "$NODESOURCE_SCRIPT"
    rm "$NODESOURCE_SCRIPT"
    sudo dnf install -y nodejs
else
    echo "Skipping NodeSource install (set CHEZMOI_ALLOW_REMOTE_INSTALL=1 to enable)"
    echo "Note: You can install Node.js via your distro repos or module streams."
fi
{{- end }}

{{- if .features.golang }}
# Install Go from official source
GO_VERSION=$(curl -fsSL https://go.dev/VERSION?m=text | head -n1)
GO_TARBALL="${GO_VERSION}.linux-amd64.tar.gz"
curl -fsSLO "https://go.dev/dl/${GO_TARBALL}"
curl -fsSLO "https://go.dev/dl/${GO_TARBALL}.sha256"
verify_sha256 "${GO_TARBALL}" "$(cat ${GO_TARBALL}.sha256)"
sudo rm -rf /usr/local/go
sudo tar -C /usr/local -xzf "${GO_TARBALL}"
rm "${GO_TARBALL}" "${GO_TARBALL}.sha256"
{{- end }}

{{- if .features.docker }}
# Install Docker from official repo
sudo dnf config-manager --add-repo https://download.docker.com/linux/rhel/docker-ce.repo
sudo dnf install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
sudo systemctl enable --now docker
sudo usermod -aG docker $USER
{{- end }}

{{- if .features.kubernetes }}
# Install kubectl
KUBECTL_VERSION=$(curl -fsSL https://dl.k8s.io/release/stable.txt)
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl"
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256"
verify_sha256 "kubectl" "$(cat kubectl.sha256)"
sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
rm kubectl kubectl.sha256
{{- end }}

{{- end }}

{{- if .features.editors_full }}
# Install vim-plug for Vim
if [[ ! -f ~/.vim/autoload/plug.vim ]]; then
    curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
        https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi
{{- end }}

# Fix package naming inconsistencies on Debian/Ubuntu
{{- if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") }}
echo "Creating symlinks for renamed packages..."

# bat is installed as batcat on Ubuntu/Debian
if command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1; then
    mkdir -p ~/.local/bin
    ln -sf "$(which batcat)" ~/.local/bin/bat
    echo "  Created bat -> batcat symlink"
fi

# fd-find is installed as fdfind on Ubuntu/Debian
if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
    mkdir -p ~/.local/bin
    ln -sf "$(which fdfind)" ~/.local/bin/fd
    echo "  Created fd -> fdfind symlink"
fi

# Ensure ~/.local/bin is in PATH (it will be after shell restart)
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    echo "Note: ~/.local/bin will be added to PATH after shell restart"
fi
{{- end }}

echo "Package installation complete!"
echo ""
echo "Note: Some tools may require a shell restart to be available in PATH"
{{- if .features.docker }}
echo "Note: Docker group membership requires logout/login to take effect"
{{- end }}
