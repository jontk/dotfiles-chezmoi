#!/bin/bash
set -e

{{- if eq .chezmoi.os "darwin" }}
# macOS: Package installation is handled by nix-darwin (nixconf).
# All CLI tools, fonts, and GUI casks are declared in:
#   nixconf/hosts/macos-laptop/default.nix
#
# nix-darwin manages:
#   - environment.systemPackages (CLI tools via nix)
#   - homebrew.brews (services: postgresql, redis, nginx; macOS-only tools)
#   - homebrew.casks (GUI apps: docker, zed, firefox, vscode, etc.)
#   - fonts.packages (nerd fonts)
#
# To apply: darwin-rebuild switch --flake ~/src/github.com/jontk/nixconf
#
# The following brew installs are kept commented out as reference for
# non-nix macOS machines or if nix-darwin is not available.

# brew install git curl wget
# brew install tmux reattach-to-user-namespace zellij
# brew install vim neovim
# brew install --cask zed
# brew install python
# brew install --cask docker
# brew install kubectl k9s helm kubectx stern kustomize
# brew install --cask font-jetbrains-mono-nerd-font
# brew install tree htop watch ncdu duf dust procs tldr
# brew install nmap mtr
# brew install make cmake pkg-config
# brew install p7zip xz
# brew install tig gitui
# brew install pandoc texlive ghostscript
# brew install ffmpeg imagemagick yt-dlp
# brew install --cask vlc mpv
# brew install task timewarrior borgbackup syncthing

echo "macOS detected — system packages managed by nix-darwin."
echo "Run 'darwin-rebuild switch --flake ~/src/github.com/jontk/nixconf' to install/update."

{{- else if eq .chezmoi.osRelease.id "fedora" }}
# Fedora
# Note: CLI tools (ripgrep, fd, bat, fzf, jq, etc.) installed via eget in user-space
echo "Installing DNF packages..."
pkgs=(
    git
    curl
    wget
    tree
    htop
    @development-tools
)
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-devel)
{{- end }}
{{- if .features.ruby }}
# Ruby build dependencies
pkgs+=(openssl-devel readline-devel zlib-devel libffi-devel libyaml-devel)
{{- end }}
{{- if .features.docker }}
pkgs+=(docker docker-compose)
{{- end }}
{{- if .features.kubernetes }}
pkgs+=(kubectl)
{{- end }}
sudo dnf install -y "${pkgs[@]}"


{{- else if eq .chezmoi.osRelease.id "ubuntu" }}
# Ubuntu/Debian
# Note: CLI tools (ripgrep, fd, bat, fzf, jq, etc.) installed via eget in user-space
echo "Installing APT packages..."
pkgs=(
    git
    curl
    wget
    tree
    htop
    build-essential
    unzip
)
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-venv python3-dev)
{{- end }}
{{- if .features.ruby }}
# Ruby build dependencies
pkgs+=(autoconf patch rustc libssl-dev libyaml-dev libreadline6-dev zlib1g-dev libgmp-dev libncurses5-dev libffi-dev libgdbm6 libgdbm-dev libdb-dev uuid-dev)
{{- end }}
{{- if .features.docker }}
pkgs+=(docker.io docker-compose)
{{- end }}
sudo apt update
sudo apt install -y "${pkgs[@]}"

{{- if .features.kubernetes }}
# Install kubectl (from official k8s repo)
KUBECTL_VERSION=$(curl -fsSL https://dl.k8s.io/release/stable.txt)
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl"
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256"
verify_sha256 "kubectl" "$(cat kubectl.sha256)"
sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
rm kubectl kubectl.sha256
{{- end }}

{{- else if or (eq .chezmoi.osRelease.id "rhel") (eq .chezmoi.osRelease.id "rocky") (eq .chezmoi.osRelease.id "almalinux") }}
# RHEL/Rocky/AlmaLinux
# Note: CLI tools (ripgrep, fd, bat, fzf, jq, etc.) installed via eget in user-space
echo "Installing DNF packages..."
pkgs=(
    git
    curl
    wget
    tree
    htop
    @development-tools
    unzip
)
{{- if .features.tmux }}
pkgs+=(tmux)
{{- end }}
{{- if .features.editors_full }}
pkgs+=(vim)
{{- if .features.beta_features }}
pkgs+=(neovim)
{{- end }}
{{- end }}
{{- if .features.python }}
pkgs+=(python3 python3-pip python3-devel)
{{- end }}
{{- if .features.ruby }}
# Ruby build dependencies
pkgs+=(openssl-devel readline-devel zlib-devel libffi-devel libyaml-devel)
{{- end }}
sudo dnf install -y "${pkgs[@]}"

{{- if .features.docker }}
# Install Docker from official repo
sudo dnf config-manager --add-repo https://download.docker.com/linux/rhel/docker-ce.repo
sudo dnf install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
sudo systemctl enable --now docker
sudo usermod -aG docker $USER
{{- end }}

{{- if .features.kubernetes }}
# Install kubectl
KUBECTL_VERSION=$(curl -fsSL https://dl.k8s.io/release/stable.txt)
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl"
curl -fsSLO "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl.sha256"
verify_sha256 "kubectl" "$(cat kubectl.sha256)"
sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
rm kubectl kubectl.sha256
{{- end }}

{{- else if eq .chezmoi.osRelease.id "nixos" }}
# NixOS
# System packages are managed declaratively via NixOS configuration (configuration.nix / flake.nix).
# Only user-space tools (eget, uv, cargo, fnm, Go, etc.) are installed by the next script.
echo "NixOS detected — skipping system package installation."
echo "System packages should be managed via your NixOS configuration."
echo "User-space tools will be installed separately to ~/.local/bin."

{{- end }}

{{- if .features.editors_full }}
# Install vim-plug for Vim
if [[ ! -f ~/.vim/autoload/plug.vim ]]; then
    curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
        https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi
{{- end }}

# Ensure ~/.local/bin directory exists for user-space tools
mkdir -p ~/.local/bin

echo "Package installation complete!"
echo ""
echo "Note: Some tools may require a shell restart to be available in PATH"
{{- if .features.docker }}
echo "Note: Docker group membership requires logout/login to take effect"
{{- end }}
