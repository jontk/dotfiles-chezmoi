# Tmux configuration
# Managed by chezmoi - Profile: {{ .profile }}

# =============================================================================
# General Settings
# =============================================================================

# Keep default Ctrl-b prefix for consistency with stock tmux

# Default shell
set -g default-shell /bin/zsh

# Enable mouse support
set -g mouse on

# Start windows and panes at 1, not 0
set -g base-index 1
setw -g pane-base-index 1

# Renumber windows when one is closed
set -g renumber-windows on

# Increase history limit
set -g history-limit 10000

# No delay for escape key press
set -sg escape-time 0

# =============================================================================
# Terminal Settings
# =============================================================================

# True color support
set -g default-terminal "tmux-256color"
set -sa terminal-overrides ',xterm-256color:RGB'
set -sa terminal-overrides ',alacritty:RGB'
set -sa terminal-overrides ',kitty:RGB'
set -sa terminal-overrides ',xterm-kitty:RGB'
set -sa terminal-overrides ',ghostty:RGB'

# Focus events (for vim/neovim)
set -g focus-events on

# =============================================================================
# Window/Pane Settings
# =============================================================================

# Set window notifications
setw -g monitor-activity on
set -g visual-activity on

# Disable aggressive resize (for iTerm 2 compatibility)
setw -g aggressive-resize off

# Pane border status
set -g pane-border-status top
set -g pane-border-format "#{pane_index} #{pane_current_command}"

# =============================================================================
# Key Bindings
# =============================================================================

# Quick pane selection
bind -r C-h select-window -t :-
bind -r C-l select-window -t :+

# Synchronize panes
bind S setw synchronize-panes

# Clear screen and history
bind -n C-l send-keys C-l \; run 'sleep 0.1' \; clear-history

# Session management
bind C-c new-session
bind C-f command-prompt -p find-session 'switch-client -t %%'

# Window management
bind -r Tab last-window

# Additional split bindings (keep defaults " and % as well)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# =============================================================================
# Copy Mode (vi style)
# =============================================================================

setw -g mode-keys vi

bind Enter copy-mode
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind -T copy-mode-vi Escape send-keys -X cancel

# =============================================================================
# Smart Pane Switching (Vim-aware)
# =============================================================================

# Smart pane switching with awareness of Vim splits
is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind-key -n 'C-h' if-shell "$is_vim" 'send-keys C-h'  'select-pane -L'
bind-key -n 'C-j' if-shell "$is_vim" 'send-keys C-j'  'select-pane -D'
bind-key -n 'C-k' if-shell "$is_vim" 'send-keys C-k'  'select-pane -U'
bind-key -n 'C-l' if-shell "$is_vim" 'send-keys C-l'  'select-pane -R'

# Pane resizing
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# =============================================================================
# Project Shortcuts
# =============================================================================

bind P new-window -n project -c "~/Projects"
bind D new-window -n dotfiles -c "{{ .chezmoi.sourceDir }}"

# =============================================================================
# Status Bar
# =============================================================================

set -g status-interval 5
set -g status-justify centre
set -g window-status-separator " | "

# Status bar colors (Dracula theme)
set -g status-style 'bg=#282a36 fg=#f8f8f2'
set -g status-left-length 40
set -g status-right-length 60

set -g status-left '#[fg=#50fa7b,bold]#S #[fg=#bd93f9]│ #[fg=#f8f8f2]#I:#P'
set -g status-right '#[fg=#8be9fd]%H:%M #[fg=#bd93f9]│ #[fg=#ff79c6]%d-%b-%Y'

# Window status
set -g window-status-format '#[fg=#6272a4]#I:#W'
set -g window-status-current-format '#[fg=#50fa7b,bold]#I:#W*'

# Pane borders (Dracula theme)
set -g pane-border-style 'fg=#6272a4'
set -g pane-active-border-style 'fg=#50fa7b'

# Message style
set -g message-style 'bg=#44475a fg=#f8f8f2'

# =============================================================================
# Platform-specific Settings
# =============================================================================

{{- if eq .chezmoi.os "darwin" }}
# macOS specific
# Use system clipboard
set -g default-command "reattach-to-user-namespace -l ${SHELL}"
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{- else }}
# Linux specific
# Use xclip or wl-copy for clipboard
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
{{- end }}
