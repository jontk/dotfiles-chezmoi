# Alacritty Terminal Configuration
# Managed by chezmoi - Profile: {{ .profile }}

# =============================================================================
# General
# =============================================================================
[general]
live_config_reload = true

# =============================================================================
# Window
# =============================================================================
[window]
dynamic_title = true
opacity = 0.95
{{- if eq .chezmoi.os "darwin" }}
decorations = "buttonless"
{{- else }}
decorations = "full"
{{- end }}

[window.dimensions]
columns = 120
lines = 40

[window.padding]
x = 5
y = 5

# =============================================================================
# Scrolling
# =============================================================================
[scrolling]
history = 10000
multiplier = 3

# =============================================================================
# Font
# =============================================================================
[font]
{{- if eq .profile "experimental" }}
size = 14.0
{{- else }}
size = 12.0
{{- end }}

{{- if .features.fonts }}
[font.normal]
family = "JetBrainsMono Nerd Font"
style = "Regular"

[font.bold]
family = "JetBrainsMono Nerd Font"
style = "Bold"

[font.italic]
family = "JetBrainsMono Nerd Font"
style = "Italic"

[font.bold_italic]
family = "JetBrainsMono Nerd Font"
style = "Bold Italic"
{{- else }}
[font.normal]
family = "monospace"
style = "Regular"
{{- end }}

[font.offset]
x = 0
y = 1

# =============================================================================
# Cursor
# =============================================================================
[cursor]
thickness = 0.15
unfocused_hollow = true
vi_mode_style = "None"

[cursor.style]
blinking = "Off"
shape = "Block"

# =============================================================================
# Terminal
# =============================================================================
[terminal]
osc52 = "CopyPaste"

# =============================================================================
# Mouse
# =============================================================================
[mouse]
hide_when_typing = true

# =============================================================================
# Selection
# =============================================================================
[selection]
save_to_clipboard = true

# =============================================================================
# Bell
# =============================================================================
[bell]
animation = "EaseOutExpo"
color = "#ffffff"
duration = 0

# =============================================================================
# Colors (Dracula)
# =============================================================================
[colors.primary]
background = "#282a36"
foreground = "#f8f8f2"
bright_foreground = "#ffffff"

[colors.cursor]
cursor = "CellForeground"
text = "CellBackground"

[colors.selection]
background = "#44475a"
text = "CellForeground"

[colors.normal]
black = "#000000"
red = "#ff5555"
green = "#50fa7b"
yellow = "#f1fa8c"
blue = "#bd93f9"
magenta = "#ff79c6"
cyan = "#8be9fd"
white = "#bfbfbf"

[colors.bright]
black = "#4d4d4d"
red = "#ff6e67"
green = "#5af78e"
yellow = "#f4f99d"
blue = "#caa9fa"
magenta = "#ff92d0"
cyan = "#9aedfe"
white = "#e6e6e6"

# =============================================================================
# Keyboard bindings
# =============================================================================
[keyboard]
{{- if eq .chezmoi.os "darwin" }}
# macOS keyboard shortcuts
bindings = [
    # Clipboard
    { key = "C", mods = "Command", action = "Copy" },
    { key = "V", mods = "Command", action = "Paste" },

    # Window management
    { key = "Q", mods = "Command", action = "Quit" },
    { key = "N", mods = "Command", action = "SpawnNewInstance" },
    { key = "Return", mods = "Command", action = "ToggleFullscreen" },

    # Font size
    { key = "Plus", mods = "Command", action = "IncreaseFontSize" },
    { key = "Minus", mods = "Command", action = "DecreaseFontSize" },
    { key = "Key0", mods = "Command", action = "ResetFontSize" },

    # Scrolling
    { key = "PageUp", mods = "Shift", action = "ScrollPageUp" },
    { key = "PageDown", mods = "Shift", action = "ScrollPageDown" },
    { key = "Home", mods = "Shift", action = "ScrollToTop" },
    { key = "End", mods = "Shift", action = "ScrollToBottom" },
]
{{- else }}
# Linux keyboard shortcuts
bindings = [
    # Clipboard
    { key = "C", mods = "Control|Shift", action = "Copy" },
    { key = "V", mods = "Control|Shift", action = "Paste" },

    # Window management
    { key = "N", mods = "Control|Shift", action = "SpawnNewInstance" },
    { key = "Return", mods = "Control|Shift", action = "ToggleFullscreen" },

    # Font size
    { key = "Plus", mods = "Control", action = "IncreaseFontSize" },
    { key = "Minus", mods = "Control", action = "DecreaseFontSize" },
    { key = "Key0", mods = "Control", action = "ResetFontSize" },

    # Scrolling
    { key = "PageUp", mods = "Shift", action = "ScrollPageUp" },
    { key = "PageDown", mods = "Shift", action = "ScrollPageDown" },
    { key = "Home", mods = "Shift", action = "ScrollToTop" },
    { key = "End", mods = "Shift", action = "ScrollToBottom" },
]
{{- end }}
