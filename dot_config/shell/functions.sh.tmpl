# Shared shell functions
# This file is sourced by both bash and zsh
{{- if .shell.enable_functions }}

# Extract various archive formats
_extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)   tar xvjf "$1"    ;;
            *.tar.gz)    tar xvzf "$1"    ;;
            *.tar.xz)    tar xvJf "$1"    ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xvf "$1"     ;;
            *.tbz2)      tar xvjf "$1"    ;;
            *.tgz)       tar xvzf "$1"    ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "Don't know how to extract '$1'" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Create backup of file or directory
_backup() {
    local item="$1"
    if [[ -z "$item" ]]; then
        echo "Usage: backup <file_or_directory>"
        return 1
    fi

    local backup_name="${item}_backup_$(date +%Y%m%d_%H%M%S)"
    cp -r "$item" "$backup_name"
    echo "Backup created: $backup_name"
}

# Search for files containing text
_search() {
    local pattern="$1"
    local path="${2:-.}"

    if [[ -z "$pattern" ]]; then
        echo "Usage: search <pattern> [path]"
        return 1
    fi

    if command -v rg >/dev/null 2>&1; then
        rg "$pattern" "$path"
    elif command -v ag >/dev/null 2>&1; then
        ag "$pattern" "$path"
    else
        grep -r "$pattern" "$path"
    fi
}

# Make directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Find files by name pattern (ff avoids conflict with fd binary/alias)
ff() {
    find . -type f -name "*$1*" 2>/dev/null
}

# Find directories by name pattern
fdir() {
    find . -type d -name "*$1*" 2>/dev/null
}

# Quick web search
websearch() {
    local query="$*"
    local url="https://www.google.com/search?q=${query// /+}"

    case "$(uname -s)" in
        Darwin*) open "$url" ;;
        Linux*) xdg-open "$url" ;;
        *) echo "Search URL: $url" ;;
    esac
}

# Show system information
sysinfo() {
    echo "System Information:"
    echo "  OS: $(uname -s)"
    echo "  Kernel: $(uname -r)"
    echo "  Architecture: $(uname -m)"
    echo "  Hostname: $(hostname)"
    echo "  Uptime: $(uptime | cut -d',' -f1 | cut -d' ' -f4-)"
    echo "  Load: $(uptime | rev | cut -d':' -f1 | rev)"
    echo "  Memory: $(free -h 2>/dev/null | grep '^Mem:' | awk '{print $3 "/" $2}' || echo 'N/A')"
    echo "  Disk: $(df -h . | tail -1 | awk '{print $3 "/" $2 " (" $5 " used)"}')"
}

# Process management helpers
psg() {
    ps aux | grep -v grep | grep -i "$1"
}

# Path management
path_add() {
    if [[ -d "$1" ]] && [[ ":$PATH:" != *":$1:"* ]]; then
        export PATH="$1:$PATH"
    fi
}

path_remove() {
    export PATH=$(echo ":$PATH:" | sed "s|:$1:|:|g" | sed 's/^://;s/:$//')
}

# ============================================================================
# Secrets Management
# ============================================================================

secrets() {
  local secrets_dir="$HOME/.local/share/secrets"

  if [[ ! -d "$secrets_dir" ]]; then
    echo "Secrets directory not found. Creating: $secrets_dir"
    mkdir -p "$secrets_dir"
    return 1
  fi

  case "$1" in
    list|ls)
      ls -la "$secrets_dir"
      ;;
    edit)
      ${EDITOR:-nvim} "$secrets_dir/${2:-.env}"
      ;;
    view)
      cat "$secrets_dir/${2:-.env}"
      ;;
    source)
      if [[ -f "$secrets_dir/${2:-.env}" ]]; then
        source "$secrets_dir/${2:-.env}"
        echo "Sourced secrets from: $secrets_dir/${2:-.env}"
      else
        echo "Secret file not found: $secrets_dir/${2:-.env}"
        return 1
      fi
      ;;
    *)
      echo "Usage: secrets {list|edit|view|source} [filename]"
      return 1
      ;;
  esac
}

edit-secrets() {
  secrets edit "$1"
}

secret-status() {
  local secrets_dir="$HOME/.local/share/secrets"
  if [[ -d "$secrets_dir" ]]; then
    echo "Secrets directory: $secrets_dir"
    echo "Files:"
    ls -1 "$secrets_dir"
  else
    echo "No secrets directory found"
  fi
}

# ============================================================================
# NixOS System Maintenance
# ============================================================================
{{- if eq .chezmoi.os "linux" }}

nix-update() {
  echo "Updating flake inputs..."
  cd "$CONFIG_ROOT" && nix flake update --commit-lock-file
}

nix-rollback() {
  echo "Rolling back to previous generation..."
  sudo nixos-rebuild switch --rollback
}

nix-maintain() {
  echo "Running garbage collection..."
  nix-collect-garbage -d
  echo "Optimizing store..."
  nix-store --optimize
}

system-status() {
  echo "=== NixOS System Status ==="
  echo ""
  echo "Current generation:"
  sudo nix-env --list-generations --profile /nix/var/nix/profiles/system | tail -5
  echo ""
  echo "Disk usage:"
  df -h / /nix
  echo ""
  echo "Store size:"
  du -sh /nix/store
}

system-health() {
  echo "=== System Health Check ==="
  echo ""
  echo "Failed systemd services:"
  systemctl --failed
  echo ""
  echo "Recent journal errors:"
  journalctl -p err -n 20 --no-pager
}

system-cleanup() {
  echo "=== System Cleanup ==="
  echo "Removing old generations (keeping last 5)..."
  sudo nix-env --delete-generations +5 --profile /nix/var/nix/profiles/system
  echo "Garbage collection..."
  sudo nix-collect-garbage -d
  echo "Optimizing store..."
  sudo nix-store --optimize
  echo "Done!"
}

quick-update() {
  cd "$CONFIG_ROOT" && git pull && sudo nixos-rebuild switch --flake .#
}

emergency-rollback() {
  sudo nixos-rebuild switch --rollback && echo "Rolled back. Rebooting in 5 seconds..." && sleep 5 && sudo reboot
}

system-backup() {
  local backup_dir="$HOME/backups/system-$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$backup_dir"
  echo "Backing up to: $backup_dir"
  cp -r "$CONFIG_ROOT" "$backup_dir/"
  cp /etc/nixos/hardware-configuration.nix "$backup_dir/" 2>/dev/null || true
  echo "Backup complete!"
}

{{- end }}

# ============================================================================
# Development Helpers
# ============================================================================

# Find and cd to a git repository
repo() {
  local repo_dir
  repo_dir=$(find ~/src -maxdepth 3 -type d -name .git 2>/dev/null | sed 's|/.git$||' | fzf)
  if [[ -n "$repo_dir" ]]; then
    cd "$repo_dir" || return
  fi
}

# Quick project switcher
proj() {
  local project
  project=$(ls -1 ~/src/github.com/{{ .github_username }}/ 2>/dev/null | fzf)
  if [[ -n "$project" ]]; then
    cd "$HOME/src/github.com/{{ .github_username }}/$project" || return
  fi
}

{{- end }}
