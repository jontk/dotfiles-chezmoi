#!/bin/sh
# POSIX-safe shell environment configuration
# Portable environment variables for login shells
# Profile: {{ .profile }}

# XDG Base Directory Specification
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CONFIG_HOME XDG_DATA_HOME XDG_CACHE_HOME XDG_STATE_HOME

# Create XDG directories if they don't exist
mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_CACHE_HOME" "$XDG_STATE_HOME"

# Path configuration - add common development paths
PATH="$HOME/.local/bin:$PATH"

# Development language paths
GOPATH="${GOPATH:-$XDG_DATA_HOME/go}"
CARGO_HOME="${CARGO_HOME:-$XDG_DATA_HOME/cargo}"
RUSTUP_HOME="${RUSTUP_HOME:-$XDG_DATA_HOME/rustup}"
NPM_CONFIG_PREFIX="${NPM_CONFIG_PREFIX:-$XDG_DATA_HOME/npm}"
export GOPATH CARGO_HOME RUSTUP_HOME NPM_CONFIG_PREFIX

# Add development tool paths to PATH
PATH="$HOME/go/bin:$GOPATH/bin:$CARGO_HOME/bin:$NPM_CONFIG_PREFIX/bin:$PATH"

{{- if .features.golang }}
# User-space Go installation (takes precedence over system Go)
if [ -d "$HOME/.local/go" ]; then
    GOROOT="$HOME/.local/go"
    export GOROOT
    PATH="$GOROOT/bin:$PATH"
fi
{{- end }}

{{- if .features.nodejs }}
# Bun - JavaScript runtime & package manager
BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
export BUN_INSTALL
PATH="$BUN_INSTALL/bin:$PATH"
{{- end }}

# Rust/Cargo - source cargo env if installed via rustup
if [ -f "$CARGO_HOME/env" ]; then
    . "$CARGO_HOME/env"
fi

{{- if .features.ruby }}
# rbenv - Ruby version manager
RBENV_ROOT="${RBENV_ROOT:-$HOME/.rbenv}"
export RBENV_ROOT
if [ -d "$RBENV_ROOT/bin" ]; then
    PATH="$RBENV_ROOT/bin:$PATH"
fi
{{- end }}

{{- if .features.java }}
# SDKMAN - JVM ecosystem manager
SDKMAN_DIR="${SDKMAN_DIR:-$HOME/.sdkman}"
export SDKMAN_DIR
{{- end }}

{{- if .features.compilers }}
# Spack - package manager for compilers
SPACK_ROOT="${SPACK_ROOT:-$HOME/.local/spack}"
export SPACK_ROOT
{{- end }}

# Editor configuration
EDITOR="${EDITOR:-{{ .editor.default }}}"
if ! command -v "$EDITOR" >/dev/null 2>&1; then
    EDITOR="vim"
fi
VISUAL="${VISUAL:-$EDITOR}"
SUDO_EDITOR="$EDITOR"
export EDITOR VISUAL SUDO_EDITOR

# Pager configuration
PAGER="${PAGER:-less}"
LESS="${LESS:--R -F -X}"
LESSHISTFILE="${LESSHISTFILE:-$XDG_STATE_HOME/less/history}"
export PAGER LESS LESSHISTFILE

# Language and locale settings
LANG="${LANG:-en_US.UTF-8}"
LC_ALL="${LC_ALL:-en_US.UTF-8}"
LC_CTYPE="${LC_CTYPE:-en_US.UTF-8}"
export LANG LC_ALL LC_CTYPE

# Shell history settings (POSIX-friendly defaults)
HISTSIZE="${HISTSIZE:-100000}"
HISTFILESIZE="${HISTFILESIZE:-100000}"
export HISTSIZE HISTFILESIZE

# Tool-specific configurations
RIPGREP_CONFIG_PATH="${RIPGREP_CONFIG_PATH:-$XDG_CONFIG_HOME/ripgrep/config}"
INPUTRC="${INPUTRC:-$XDG_CONFIG_HOME/readline/inputrc}"
GNUPGHOME="${GNUPGHOME:-$XDG_DATA_HOME/gnupg}"
GPG_TTY="$(tty 2>/dev/null || echo not-a-tty)"
export RIPGREP_CONFIG_PATH INPUTRC GNUPGHOME GPG_TTY

{{- if .features.docker }}
# Docker configuration
DOCKER_CONFIG="${DOCKER_CONFIG:-$XDG_CONFIG_HOME/docker}"
DOCKER_BUILDKIT="${DOCKER_BUILDKIT:-1}"
COMPOSE_DOCKER_CLI_BUILD="${COMPOSE_DOCKER_CLI_BUILD:-1}"
export DOCKER_CONFIG DOCKER_BUILDKIT COMPOSE_DOCKER_CLI_BUILD
{{- end }}

{{- if .features.kubernetes }}
# Kubernetes configuration
KUBECONFIG="${KUBECONFIG:-$XDG_CONFIG_HOME/kube/config}"
KUBE_EDITOR="${KUBE_EDITOR:-$EDITOR}"
export KUBECONFIG KUBE_EDITOR
{{- end }}

{{- if .features.nodejs }}
# Node.js configuration
NODE_REPL_HISTORY="${NODE_REPL_HISTORY:-$XDG_STATE_HOME/node/repl_history}"
NPM_CONFIG_USERCONFIG="${NPM_CONFIG_USERCONFIG:-$XDG_CONFIG_HOME/npm/npmrc}"
NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-$XDG_CACHE_HOME/npm}"
export NODE_REPL_HISTORY NPM_CONFIG_USERCONFIG NPM_CONFIG_CACHE
{{- end }}

{{- if .features.python }}
# Python configuration
PYTHONSTARTUP="${PYTHONSTARTUP:-$XDG_CONFIG_HOME/python/startup.py}"
PYTHON_HISTORY="${PYTHON_HISTORY:-$XDG_STATE_HOME/python/history}"
PYTHONHISTFILE="${PYTHONHISTFILE:-$XDG_STATE_HOME/python/history}"
PYTHONUSERBASE="${PYTHONUSERBASE:-$XDG_DATA_HOME/python}"
WORKON_HOME="${WORKON_HOME:-$XDG_DATA_HOME/virtualenvs}"
PIPENV_VENV_IN_PROJECT="${PIPENV_VENV_IN_PROJECT:-1}"
export PYTHONSTARTUP PYTHON_HISTORY PYTHONHISTFILE PYTHONUSERBASE WORKON_HOME PIPENV_VENV_IN_PROJECT
{{- end }}

# Platform-specific configurations
case "$(uname -s)" in
    Darwin)
        # macOS specific
        HOMEBREW_NO_ANALYTICS=1
        HOMEBREW_NO_AUTO_UPDATE=1
        HOMEBREW_NO_INSTALL_CLEANUP=1
        HOMEBREW_BUNDLE_FILE="${HOMEBREW_BUNDLE_FILE:-$XDG_CONFIG_HOME/homebrew/Brewfile}"
        export HOMEBREW_NO_ANALYTICS HOMEBREW_NO_AUTO_UPDATE HOMEBREW_NO_INSTALL_CLEANUP HOMEBREW_BUNDLE_FILE

        # Use GNU utilities if available
        if [ -d /opt/homebrew/opt/coreutils/libexec/gnubin ]; then
            PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"
        fi

        # Add Homebrew to PATH
        if [ -d /opt/homebrew/bin ]; then
            PATH="/opt/homebrew/bin:$PATH"
        elif [ -d /usr/local/bin ]; then
            PATH="/usr/local/bin:$PATH"
        fi
        ;;
    Linux)
        # Linux specific
        SYSTEMD_EDITOR="$EDITOR"
        export SYSTEMD_EDITOR
        ;;
esac

# Clean up PATH - remove duplicates
PATH=$(echo "$PATH" | tr ':' '\n' | awk '!seen[$0]++' | tr '\n' ':' | sed 's/:$//')
export PATH
