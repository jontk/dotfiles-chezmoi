# ~/.profile - POSIX login shell configuration
# Managed by chezmoi - Profile: {{ .profile }}
#
# This file is read by login shells (bash, sh, dash, etc.)
# It should be POSIX-compatible (no bash-specific features)

# Source POSIX-safe environment variables if present
if [ -f "$HOME/.config/shell/environment.posix.sh" ]; then
    . "$HOME/.config/shell/environment.posix.sh"
elif [ -n "${BASH_VERSION-}" ] || [ -n "${ZSH_VERSION-}" ]; then
    # Fallback for bash/zsh if POSIX file is missing
    if [ -f "$HOME/.config/shell/environment.sh" ]; then
        . "$HOME/.config/shell/environment.sh"
    fi
fi

# Set PATH (POSIX-compatible)
# Add user's private bin directories if they exist
if [ -d "$HOME/bin" ]; then
    PATH="$HOME/bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ]; then
    PATH="$HOME/.local/bin:$PATH"
fi

# Export PATH
export PATH

# Default umask
umask 022

# Source .bashrc for interactive bash shells
if [ -n "$BASH_VERSION" ]; then
    if [ -f "$HOME/.bashrc" ]; then
        . "$HOME/.bashrc"
    fi
fi

# Source .zshrc for interactive zsh shells (some systems)
if [ -n "$ZSH_VERSION" ]; then
    if [ -f "$HOME/.zshrc" ]; then
        . "$HOME/.zshrc"
    fi
fi
