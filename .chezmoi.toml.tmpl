{{- $profile := promptStringOnce . "profile" "Profile (minimal/personal/work/server/experimental)" "personal" -}}
{{- $gitEmail := promptStringOnce . "git.email" "Git email" "" -}}
{{- $gitName := promptStringOnce . "git.name" "Git name" "" -}}
{{- $githubUsername := promptStringOnce . "github_username" "GitHub username" "" -}}
{{- $workGitEmail := "" -}}
{{- $workGitName := "" -}}
{{- $workGpgKey := "" -}}
{{- if eq $profile "work" -}}
{{-   $workGitEmail = promptStringOnce . "git.workEmail" "Work Git email" "" -}}
{{-   $workGitName = promptStringOnce . "git.workName" "Work Git name" "" -}}
{{-   $workGpgKey = promptStringOnce . "git.workGpgKey" "Work GPG key (optional)" "" -}}
{{- end -}}

[data]
    profile = {{ $profile | quote }}
    hostname = {{ .chezmoi.hostname | quote }}
    github_username = {{ $githubUsername | quote }}

    [data.git]
        email = {{ $gitEmail | quote }}
        name = {{ $gitName | quote }}
        githubKey = ""
        gitlabKey = ""
        workEmail = {{ $workGitEmail | quote }}
        workName = {{ $workGitName | quote }}
        workGpgKey = {{ $workGpgKey | quote }}

    # Profile-specific feature flags
    {{- if eq $profile "minimal" }}
    [data.features]
        editors_full = false
        docker = false
        kubernetes = false
        nodejs = false
        python = false
        golang = false
        ruby = false
        java = false
        compilers = false
        fonts = false
        starship = false
        tmux = false
        beta_features = false
        work_specific = false

    {{- else if eq $profile "personal" }}
    [data.features]
        editors_full = true
        docker = true
        kubernetes = true
        nodejs = true
        python = true
        golang = true
        ruby = false
        java = false
        compilers = false
        fonts = true
        starship = true
        tmux = true
        beta_features = false
        work_specific = false

    {{- else if eq $profile "work" }}
    [data.features]
        editors_full = true
        docker = true
        kubernetes = true
        nodejs = true
        python = true
        golang = true
        ruby = false
        java = true
        compilers = false
        fonts = true
        starship = true
        tmux = true
        work_specific = true
        beta_features = false

    {{- else if eq $profile "server" }}
    [data.features]
        editors_full = false
        docker = true
        kubernetes = false
        nodejs = false
        python = false
        golang = false
        ruby = false
        java = false
        compilers = false
        fonts = false
        starship = false
        tmux = false
        minimal_prompt = true
        beta_features = false
        work_specific = false

    {{- else if eq $profile "experimental" }}
    [data.features]
        editors_full = true
        docker = true
        kubernetes = true
        nodejs = true
        python = true
        golang = true
        ruby = true
        java = true
        compilers = true
        fonts = true
        starship = true
        tmux = true
        beta_features = true
        neovim = true
        work_specific = false
    {{- end }}

    # Shell settings
    [data.shell]
        {{- if eq $profile "minimal" }}
        prompt_style = "simple"
        enable_functions = true
        {{- else if eq $profile "server" }}
        prompt_style = "simple"
        enable_functions = false
        {{- else if or (eq $profile "personal") (eq $profile "work") (eq $profile "experimental") }}
        prompt_style = "starship"
        enable_functions = true
        {{- end }}

    # Editor settings
    [data.editor]
        {{- if eq $profile "experimental" }}
        default = "nvim"
        {{- else }}
        default = "vim"
        {{- end }}

    # Work settings (empty for non-work profiles)
    [data.work]
        username = ""
        sshKey = ""
