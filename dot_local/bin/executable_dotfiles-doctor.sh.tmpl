#!/usr/bin/env bash
# shellcheck disable=SC2034
# Dotfiles health check — verifies tools, configs, and shell setup
# Usage: dotfiles-doctor [--verbose]

set -euo pipefail

VERBOSE="${1:-}"

# Colors
if [[ -t 1 ]]; then
    GREEN='\033[0;32m' RED='\033[0;31m' YELLOW='\033[1;33m' BLUE='\033[0;34m' NC='\033[0m'
else
    GREEN='' RED='' YELLOW='' BLUE='' NC=''
fi

pass=0 warn=0 fail=0

ok()   { printf '%b\n' "${GREEN}OK${NC}   $1"; ((pass++)); }
skip() { printf '%b\n' "${YELLOW}SKIP${NC} $1"; ((warn++)); }
bad()  { printf '%b\n' "${RED}FAIL${NC} $1"; ((fail++)); }

check_file() {
    local path="$1" label="${2:-$1}"
    if [[ -f "$path" ]]; then ok "$label"; else bad "$label — missing $path"; fi
}

check_dir() {
    local path="$1" label="${2:-$1}"
    if [[ -d "$path" ]]; then ok "$label"; else bad "$label — missing $path"; fi
}

check_cmd() {
    local cmd="$1" label="${2:-$1}"
    if command -v "$cmd" >/dev/null 2>&1; then
        if [[ -n "$VERBOSE" ]]; then
            local ver
            ver=$("$cmd" --version 2>/dev/null | head -1 || echo "unknown")
            ok "$label ($ver)"
        else
            ok "$label"
        fi
    else
        skip "$label — not installed"
    fi
}

check_cmd_required() {
    local cmd="$1" label="${2:-$1}"
    if command -v "$cmd" >/dev/null 2>&1; then
        ok "$label"
    else
        bad "$label — not found in PATH"
    fi
}

printf '%b\n' "${BLUE}Dotfiles Health Check${NC}"
printf '%b\n' "${BLUE}Profile: {{ .profile }}${NC}"
echo "================================================"

# ─── Core files ──────────────────────────────────────────────────────────────
echo ""
echo "Core configuration files:"
check_file ~/.bashrc ".bashrc"
check_file ~/.zshrc ".zshrc"
check_file ~/.profile ".profile"
check_file ~/.gitconfig ".gitconfig"
check_file ~/.ssh/config ".ssh/config"
check_dir ~/.git_template ".git_template"
check_file ~/.git_template/hooks/pre-commit "pre-commit hook"

# ─── Shell ───────────────────────────────────────────────────────────────────
echo ""
echo "Shell environment:"
check_file ~/.config/shell/aliases.sh "shell aliases"
check_file ~/.config/shell/environment.sh "shell environment"
{{- if .shell.enable_functions }}
check_file ~/.config/shell/functions.sh "shell functions"
{{- end }}

# ─── Required tools ──────────────────────────────────────────────────────────
echo ""
echo "Required tools:"
check_cmd_required git "git"
check_cmd_required curl "curl"
check_cmd chezmoi "chezmoi"

# ─── CLI tools ───────────────────────────────────────────────────────────────
echo ""
echo "CLI tools:"
check_cmd rg "ripgrep"
check_cmd fd "fd"
check_cmd bat "bat"
check_cmd eza "eza"
check_cmd fzf "fzf"
check_cmd delta "delta"
check_cmd lazygit "lazygit"
check_cmd jq "jq"
check_cmd yq "yq"
check_cmd zoxide "zoxide"
check_cmd gh "gh cli"

{{- if .features.starship }}

echo ""
echo "Prompt:"
check_cmd starship "starship"
if [[ -f ~/.config/starship/starship.toml ]] || [[ -f ~/.config/starship.toml ]]; then
    ok "starship config"
else
    skip "starship config — no config file found"
fi
{{- end }}

{{- if .features.editors_full }}

echo ""
echo "Editors:"
check_file ~/.vimrc ".vimrc"
check_cmd vim "vim"
{{- if and (hasKey .features "neovim") .features.neovim }}
check_cmd nvim "neovim"
check_dir ~/.config/nvim "nvim config"
{{- end }}
{{- end }}

{{- if .features.tmux }}

echo ""
echo "Terminal multiplexer:"
check_cmd tmux "tmux"
check_file ~/.tmux.conf ".tmux.conf"
{{- end }}

{{- if .features.docker }}

echo ""
echo "Containers:"
check_cmd docker "docker"
check_file ~/.config/docker/aliases.sh "docker aliases"
{{- if .features.kubernetes }}
check_cmd kubectl "kubectl"
check_file ~/.config/kubernetes/kubectl-aliases.sh "kubectl aliases"
{{- end }}
{{- end }}

# ─── Language runtimes ───────────────────────────────────────────────────────
{{- if or .features.nodejs .features.python .features.golang }}

echo ""
echo "Language runtimes:"
{{- if .features.nodejs }}
check_cmd fnm "fnm (node version manager)"
check_cmd node "node"
check_cmd bun "bun"
{{- end }}
{{- if .features.python }}
check_cmd uv "uv (python package manager)"
check_cmd python3 "python3"
{{- end }}
{{- if .features.golang }}
check_cmd go "go"
{{- end }}
check_cmd rustc "rust"
check_cmd cargo "cargo"
{{- end }}

# ─── Git configuration ──────────────────────────────────────────────────────
echo ""
echo "Git configuration:"
git_name=$(git config --global user.name 2>/dev/null || echo "")
git_email=$(git config --global user.email 2>/dev/null || echo "")
if [[ -n "$git_name" ]]; then ok "git user.name = $git_name"; else bad "git user.name not set"; fi
if [[ -n "$git_email" ]]; then ok "git user.email = $git_email"; else bad "git user.email not set"; fi

template_dir=$(git config --global init.templateDir 2>/dev/null || echo "")
if [[ -n "$template_dir" ]]; then ok "git template dir = $template_dir"; else skip "git init.templateDir not set"; fi

# ─── chezmoi state ───────────────────────────────────────────────────────────
echo ""
echo "Chezmoi:"
if command -v chezmoi >/dev/null 2>&1; then
    source_dir=$(chezmoi source-path 2>/dev/null || echo "")
    if [[ -n "$source_dir" ]] && [[ -d "$source_dir" ]]; then
        ok "source dir = $source_dir"
    else
        bad "chezmoi source directory not found"
    fi
fi

# ─── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo "================================================"
total=$((pass + warn + fail))
printf '%b\n' "${GREEN}$pass passed${NC}, ${YELLOW}$warn skipped${NC}, ${RED}$fail failed${NC} ($total checks)"

if [[ $fail -gt 0 ]]; then
    echo ""
    echo "Run 'chezmoi apply' to fix missing files, or install missing tools."
    exit 1
fi
