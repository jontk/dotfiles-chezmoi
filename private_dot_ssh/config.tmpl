# SSH Client Configuration
# Managed by chezmoi - Profile: {{ .profile }}
# Security-focused SSH configuration with best practices

# Global defaults for all hosts
Host *
    # Automatically add keys to ssh-agent
    AddKeysToAgent yes

    # Only use explicitly configured identities
    IdentitiesOnly yes

    # Hash known hosts for privacy
    HashKnownHosts yes

    # Keep connection alive with periodic checks
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Connection optimization
    TCPKeepAlive yes
    Compression yes

    # Use strong ciphers and algorithms
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr
    MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,hmac-sha2-512,hmac-sha2-256
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512,diffie-hellman-group-exchange-sha256
    HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-rsa-cert-v01@openssh.com,ssh-ed25519,ssh-rsa,ecdsa-sha2-nistp521-cert-v01@openssh.com,ecdsa-sha2-nistp384-cert-v01@openssh.com,ecdsa-sha2-nistp256-cert-v01@openssh.com,ecdsa-sha2-nistp521,ecdsa-sha2-nistp384,ecdsa-sha2-nistp256

    # Security options
    StrictHostKeyChecking ask
    VerifyHostKeyDNS yes

{{- if eq .chezmoi.os "darwin" }}
    # macOS-specific: Use Keychain for SSH keys
    UseKeychain yes
{{- end }}

# GitHub configuration
Host github.com
    HostName github.com
    User git
{{- if .git.githubKey }}
    IdentityFile {{ .git.githubKey }}
{{- else }}
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_rsa
{{- end }}

# GitLab configuration
Host gitlab.com
    HostName gitlab.com
    User git
{{- if .git.gitlabKey }}
    IdentityFile {{ .git.gitlabKey }}
{{- else }}
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_rsa
{{- end }}

{{- if .features.work_specific }}

# Work-specific SSH hosts
Host *.work.internal work-*
    User {{ .work.username | default .chezmoi.username }}
{{- if .work.sshKey }}
    IdentityFile {{ .work.sshKey }}
{{- end }}
    ForwardAgent no
    StrictHostKeyChecking yes
{{- end }}

